  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "3,000 years ago, a woman was buried with more bronze vessels than any
    king before her.\n\nShe was a queen, a high priestess, and the most feared general
    of her time. Her name was Fu Hao.\nToday, you stand in her tomb. As an archaeologist
    with a rare gift \u2014 the ability to see the past through touch \u2014 you
    have one mission: decode the oracle bones she left behind, and uncover what she
    was asking the spirits in her final days.\n\nTouch the artifacts. See her world.
    Read her bones."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
  m_sharedMaterial: {fileID: 2180264, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
